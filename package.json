{
  "name": "aider-usage",
  "version": "0.1.0",
  "description": "Offline token/cost usage reports from Aider analytics logs",
  "type": "module",
  "author": "ycaptain <cz.ycaptain@gmail.com>",
  "homepage": "https://github.com/ycaptain/aider-usage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ycaptain/aider-usage.git"
  },
  "bugs": {
    "url": "https://github.com/ycaptain/aider-usage/issues"
  },
  "bin": {
    "aider-usage": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "aider",
    "analytics",
    "token",
    "cost",
    "cli",
    "usage"
  ],
  "license": "MIT",
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "fast-check": "^3.23.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@7.33.7+sha512.7afe2410642b39c698df46da4ce5c7231a5cce360698d69f8cf8f42257d40b3e43f231053b07b8de849fd4ffbf4a71ff57b835137777a352388f3d3da747200e"
}
